{
  "buildCommand": "node build.js",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/donate", "destination": "/donate.html" },
    { "source": "/partners", "destination": "/partners.html" },
    { "source": "/nutrition", "destination": "/nutrition.html" },
    { "source": "/curriculum", "destination": "/curriculum.html" },
    { "source": "/staff", "destination": "/staff.html" },
    { "source": "/training", "destination": "/training.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
