{
  "name": "letsbeready-org",
  "version": "1.0.0",
  "private": true,
  "description": "Static site + Sanity CMS for Let's Be Ready, a Guatemalan preschool nonprofit. Class project.",
  "license": "MIT",
  "scripts": {
