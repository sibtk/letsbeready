# ============================================
# Sanity CMS (preferred — used in production)
# ============================================
SANITY_PROJECT_ID=
SANITY_DATASET=production
# Read token (optional — only needed for drafts/private datasets)
SANITY_API_TOKEN=

# ============================================
# Migration only — DO NOT add to Vercel
# Generate at: sanity.io/manage → API → Tokens → Add API token
# Permissions: "Editor" or higher
# ============================================
SANITY_WRITE_TOKEN=

# ============================================
# Studio dev (used by Sanity CLI in studio/)
# ============================================
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# ============================================
# Google Sheets (legacy — unset once migrated)
# ============================================
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=
